AUDIDISC_ENV=development
AUDIDISC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUDIDISC_TIMEZONE=America/La_Paz
AUDIDISC_FIREBASE_CHECK_REVOKED_TOKENS=false
AUDIDISC_FIREBASE_AUTH_TIMEOUT_SECONDS=6
AUDIDISC_FIRESTORE_TRANSPORT=grpc
AUDIDISC_RATE_LIMIT_ENABLED=true
AUDIDISC_RATE_LIMIT_WINDOW_SECONDS=60
AUDIDISC_RATE_LIMIT_PUBLIC_REQUESTS=120
AUDIDISC_RATE_LIMIT_AUTHENTICATED_REQUESTS=300
AUDIDISC_RATE_LIMIT_MUTATING_REQUESTS=90
AUDIDISC_RATE_LIMIT_SENSITIVE_REQUESTS=60

# Recommended: configure the service account JSON as a deployment secret.
# Keep private_key newlines escaped as \n when setting this in a single-line env var.
# AUDIDISC_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"placeholder","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-placeholder@your-project-id.iam.gserviceaccount.com","client_id":"placeholder","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-placeholder%40your-project-id.iam.gserviceaccount.com"}

# Alternative: split the service account fields. Do not commit real values.
AUDIDISC_FIREBASE_PROJECT_ID=your-project-id
AUDIDISC_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-placeholder@your-project-id.iam.gserviceaccount.com
AUDIDISC_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
AUDIDISC_FIREBASE_PRIVATE_KEY_ID=placeholder
AUDIDISC_FIREBASE_CLIENT_ID=placeholder
AUDIDISC_FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-placeholder%40your-project-id.iam.gserviceaccount.com
