rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'Administrador';
    }

    function hasPermission(permission) {
      return isAdmin()
        || (signedIn()
          && request.auth.token.permissions is list
          && request.auth.token.permissions.hasAny([permission]));
    }

    match /productos/{productId} {
      allow read: if hasPermission('inventory');
      allow create, update, delete: if hasPermission('inventory_write');
    }

    match /ventas/{saleId} {
      allow read: if hasPermission('sales') || hasPermission('history');
      allow create: if hasPermission('sales');
      allow update, delete: if hasPermission('history');
    }

    match /clientes/{customerId} {
      allow read, create, update: if hasPermission('customers');
      allow delete: if hasPermission('customers');
    }

    match /pushTokens/{tokenId} {
      allow read: if isAdmin();
      allow create, update: if signedIn();
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /audit_logs/{auditId} {
      allow read: if hasPermission('audit');
      allow write: if false;
    }

    match /roles/{roleId} {
      allow read, write: if hasPermission('users');
    }

    match /user_profiles/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || hasPermission('users'));
      allow write: if hasPermission('users');
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || hasPermission('users'));
      allow write: if hasPermission('users');
    }
  }
}
