{
  "name": "audi-disc-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "8.5.14",
    "tailwindcss": "^3.4.17"
  }
}
