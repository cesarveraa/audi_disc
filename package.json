{
  "name": "audi-disc-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:web": "npm run build --workspace @audidisc/web",
    "build:catalog": "npm run build --workspace @audidisc/catalog",
    "sync:web:android": "npm run cap:sync --workspace @audidisc/web",
    "dev:catalog": "npm run dev --workspace @audidisc/catalog",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "8.5.14",
    "@react-native/codegen": "0.85.3",
    "@react-native/babel-plugin-codegen": "0.85.3",
    "@react-native/babel-preset": "0.85.3"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "8.5.14",
    "tailwindcss": "^3.4.17"
  }
}
